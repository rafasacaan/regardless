---
import Base from './Base.astro';

interface Props {
  title: string;
  fecha: Date;
  tipo: 'tech' | 'nota';
  resumen?: string;
}

const { title, fecha, tipo, resumen } = Astro.props;

const fechaLegible = fecha.toLocaleDateString('es-CL', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const fechaISO = fecha.toISOString().slice(0, 10);
---

<Base title={`${title} — regardless`} description={resumen}>
  <main class="wrap">
    <nav class="crumb">
      <a href="/">regardless</a> / <a href="/blog/">blog</a>
    </nav>

    <header class="post-header">
      <div class="post-meta">
        <span class="post-tipo">{tipo}</span>
        <time datetime={fechaISO}>{fechaLegible}</time>
      </div>
      <h1 class="post-h1">{title}</h1>
    </header>

    <article class="prose">
      <slot />
    </article>
  </main>

  <footer class="foot">
    <span class="foot-name">un lab de rafa sacaan</span>
    <a class="foot-link" href="/blog/">← volver al blog</a>
  </footer>
</Base>
