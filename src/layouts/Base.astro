---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  htmlClass?: string;
  noindex?: boolean;
}

const {
  title = 'regardless.',
  description = 'Un laboratorio personal y experimental que crea cómplices digitales para sacar afuera las ideas que ya llevas adentro.',
  htmlClass = '',
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es" class={htmlClass}>
  <head>
    <!-- tema guardado, aplicado antes del paint para evitar flash -->
    <script is:inline>
      try{
        var t = localStorage.getItem('rgl-theme');
        if(t === 'light') document.documentElement.classList.remove('v3-dark');
        else if(t === 'dark') document.documentElement.classList.add('v3-dark');
      }catch(e){}
    </script>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-1H564NGHHD"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-1H564NGHHD');
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=6" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL('/img/og.jpg', Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/img/og.jpg', Astro.site)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=IBM+Plex+Mono:wght@300;400;500&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <link rel="alternate" type="application/rss+xml" title="regardless — blog" href="/rss.xml" />
  </head>
  <body>
    <slot />
  </body>
</html>
