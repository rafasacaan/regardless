---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latest = allPosts.find(p => p.id === '00-apertura');
const pinned2 = allPosts.find(p => p.id === '01-foundations');
const postCount = allPosts.length;
---

<Base>
  <main class="hero">
    <article class="entry">
      <h1 class="head anim d2"><span class="ghost" aria-hidden="true">regard<span class="mid">·</span>less</span><span class="ghost" aria-hidden="true">regard<span class="mid">·</span>less</span><span class="solid">regard<span class="mid">·</span>less</span></h1>
      <p class="pron anim d3"><span class="pos">(adv.)</span><span class="ipa">/rɪˈgɑːrdləs/</span></p>
      <p class="def anim d3"><span class="num">(def.)</span> Cuando algo se hace o es cierto independiente de los obstáculos o de lo que piensen los demás.</p>
      <p class="def def-lab anim d4"><span class="num">(lab.)</span> <span class="lab-text"></span><span class="lab-cursor" aria-hidden="true">|</span></p>
      <p class="def def-last anim d4"><span class="num">(n.b.)</span> Tu atención es un recurso limitado, úsala bien.</p>
    </article>

    <section class="instruments">
      <div class="cols">
        <div class="col-group anim d4">
          <div class="eyebrow">artefactos</div>
          <div class="stack">
            <span class="artifact-row"><a class="link" href="https://munra.cl" target="_blank" rel="noopener"><span class="g" aria-hidden="true">munra</span>munra<span class="arrow">↗</span></a><span class="soon">coming soon</span></span>
            <span class="artifact-desc">Pequeños modelos que generan tracks instrumentales.</span>
            <span class="artifact-row"><a class="link" href="https://heyfrank.cl" target="_blank" rel="noopener"><span class="g" aria-hidden="true">heyfrank</span>heyfrank<span class="arrow">↗</span></a><span class="soon">coming soon</span></span>
            <span class="artifact-desc">Recetas para crear música desde el mood, no desde las perillas.</span>
            <span class="artifact-row"><a class="link" href="https://yoescritor.cl" target="_blank" rel="noopener"><span class="g" aria-hidden="true">yoescritor</span>yoescritor<span class="arrow">↗</span></a><span class="soon">coming soon</span></span>
            <span class="artifact-desc">Encuentra al escritor que ya vive en ti.</span>
          </div>
        </div>
        <div class="col-group anim d5">
          <div class="eyebrow">notas</div>
          <div class="stack">
            <a class="link" href="/blog/"><span class="g" aria-hidden="true">blog</span>blog<span class="arrow">→</span></a>
            <span class="post-count">{postCount} posts</span>
            {pinned2 && (
              <a class="latest-post" href={`/blog/${pinned2.id}/`}>
                <div class="latest-meta">
                  <span class="live-dot" aria-hidden="true"></span>
                  <span>{pinned2.data.fecha.toLocaleDateString('es-CL', { day:'numeric', month:'short', year:'numeric' })}</span>
                  <span class="latest-tipo">{pinned2.data.tipo}</span>
                </div>
                <span class="latest-title">{pinned2.data.title}</span>
              </a>
            )}
            {latest && (
              <a class="latest-post" href={`/blog/${latest.id}/`}>
                <div class="latest-meta">
                  <span class="live-dot" aria-hidden="true"></span>
                  <span>{latest.data.fecha.toLocaleDateString('es-CL', { day:'numeric', month:'short', year:'numeric' })}</span>
                  <span class="latest-tipo">{latest.data.tipo}</span>
                </div>
                <span class="latest-title">{latest.data.title}</span>
              </a>
            )}
          </div>
        </div>
        <div class="col-group anim d5">
          <div class="eyebrow">música</div>
          <div class="stack">
            <a class="link" href="https://munra.bandcamp.com" target="_blank" rel="noopener"><span class="g" aria-hidden="true">bandcamp</span>bandcamp<span class="arrow">↗</span></a>
            <a class="latest-post" href="https://munra.bandcamp.com" target="_blank" rel="noopener" style="margin-top:.5em;">
              <span class="latest-meta">
                <span class="live-dot" aria-hidden="true"></span>
                <span class="latest-tipo">latest</span>
              </span>
              <span class="latest-title">Primeros samples a mano de un 808</span>
            </a>
          </div>
        </div>
        <div class="col-group anim d5">
          <div class="eyebrow">contacto</div>
          <div class="stack">
            <a class="link" href="mailto:rafasacaan@gmail.com"><span class="g" aria-hidden="true">email</span>email<span class="arrow">↗</span></a>
            <a class="link" href="https://www.linkedin.com/in/rafaelsacaanamunategui/" target="_blank" rel="noopener"><span class="g" aria-hidden="true">linkedin</span>linkedin<span class="arrow">↗</span></a>
            <a class="link" href="https://github.com/rafasacaan" target="_blank" rel="noopener"><span class="g" aria-hidden="true">github</span>github<span class="arrow">↗</span></a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="foot anim d5">
    <a class="foot-link" href="mailto:rafasacaan@gmail.com">un lab de rafa sacaan</a>
    <span>actualizado junio 2026</span>
  </footer>

  <script is:inline>
    (function(){
      const head = document.querySelector('.head');
      if(!head || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      function glitch(){
        const isStatic = Math.random() < 0.35;
        const cls = isStatic ? 'glitching-static' : 'glitching';
        const dur = isStatic ? 200 : 420;
        head.classList.add(cls);
        setTimeout(() => head.classList.remove(cls), dur);

        // a veces el glitch estático dispara un segundo pequeño
        if(isStatic && Math.random() < 0.5){
          setTimeout(() => {
            head.classList.add('glitching-static');
            setTimeout(() => head.classList.remove('glitching-static'), 180);
          }, 280);
        }

        setTimeout(glitch, 3500 + Math.random() * 7000);
      }

      setTimeout(glitch, 2500 + Math.random() * 3000);

      // typewriter (lab.)
      const labText = document.querySelector('.lab-text');
      const labCursor = document.querySelector('.lab-cursor');
      const labPlain = 'Un laboratorio experimental que construye artefactos digitales para que personas normales saquen afuera las ideas que llevan dentro.';
      const labHighlight = 'personas normales';
      const labFull = labPlain.replace(labHighlight, `<em class="lab-em">${labHighlight}</em>`);
      if(labText && labCursor){
        const entranceEnd = 560 + 900;
        setTimeout(() => {
          labCursor.classList.add('typing');
          let i = 0;
          const iv = setInterval(() => {
            const slice = labPlain.slice(0, ++i);
            labText.innerHTML = slice.replace(labHighlight, `<em class="lab-em">${labHighlight}</em>`);
            if(i >= labPlain.length){
              clearInterval(iv);
              labCursor.classList.remove('typing');
              labCursor.classList.add('done');
            }
          }, 32);
        }, entranceEnd);
      }

      // efecto atención perdida en (n.b.)
      const nb = document.querySelector('.def-last');
      if(nb){
        function loseAttention(){
          nb.classList.add('losing');
          nb.addEventListener('animationend', () => nb.classList.remove('losing'), { once:true });
          setTimeout(loseAttention, 12000 + Math.random() * 20000);
        }
        setTimeout(loseAttention, 2000 + Math.random() * 1000);
      }
    })();
  </script>
</Base>
