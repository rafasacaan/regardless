---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latest = allPosts.find(p => p.id === '00-apertura');
const pinned2 = allPosts.find(p => p.id === '01-foundations');
const postCount = allPosts.length;
---

<Base noindex={true}>
  <canvas id="dot-canvas" aria-hidden="true"></canvas>
  <main class="hero">
    <article class="entry">
      <h1 class="head anim d2"><span class="ghost" aria-hidden="true">regard<span class="mid">·</span>less</span><span class="ghost" aria-hidden="true">regard<span class="mid">·</span>less</span><span class="solid">regard<span class="mid">·</span>less</span></h1>
      <p class="pron anim d3"><span class="pos">(adv.)</span><span class="ipa">/rɪˈgɑːrdləs/</span></p>
      <p class="def def-def anim d3"><span class="num">(def.)</span> <span class="def-text"></span><span class="type-cursor def-cursor" aria-hidden="true">|</span></p>
      <p class="def def-lab anim d4"><span class="num">(lab.)</span> <span class="lab-text"></span><span class="type-cursor lab-cursor" aria-hidden="true">|</span></p>
      <p class="def def-cred anim d5"><span class="num">(cred.)</span> <span class="cred-text"></span><span class="type-cursor cred-cursor" aria-hidden="true">|</span></p>
    </article>

    <section class="instruments">
      <div class="cols">
        <div class="col-group anim d4">
          <div class="eyebrow" style="display:flex;align-items:center;gap:.5em;">artefactos <a href="https://github.com/rafasacaan" target="_blank" rel="noopener" style="display:flex;align-items:center;opacity:.35;transition:opacity .2s ease;" aria-label="GitHub"><svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg></a></div>
          <div class="stack">
            <span class="artifact-row"><a class="link" href="https://heyfrank.cl" target="_blank" rel="noopener"><span class="g" aria-hidden="true">heyfrank</span>heyfrank<span class="arrow">↗</span></a><span class="soon">coming soon</span></span>
            <span class="artifact-desc">Recetas para crear música desde el mood, no desde las perillas.</span>
            <span class="artifact-row"><a class="link" href="https://munra.cl" target="_blank" rel="noopener"><span class="g" aria-hidden="true">munra</span>munra<span class="arrow">↗</span></a><span class="soon">coming soon</span></span>
            <span class="artifact-desc">Pequeños modelos que generan tracks instrumentales.</span>
            <span class="artifact-row"><a class="link" href="https://yoescritor.cl" target="_blank" rel="noopener"><span class="g" aria-hidden="true">yoescritor</span>yoescritor<span class="arrow">↗</span></a><span class="soon">coming soon</span></span>
            <span class="artifact-desc">Encuentra al escritor que ya vive en ti.</span>
          </div>
        </div>
        <div class="col-group anim d5">
          <div class="eyebrow">notas</div>
          <div class="stack">
            <a class="link" href="/blog/"><span class="g" aria-hidden="true">blog</span>blog<span class="arrow">→</span></a>
            <span class="post-count">{postCount} posts</span>
            {pinned2 && (
              <a class="latest-post" href={`/blog/${pinned2.id}/`}>
                <div class="latest-meta">
                  <span class="live-dot" aria-hidden="true"></span>
                  <span>{pinned2.data.fecha.toLocaleDateString('es-CL', { day:'numeric', month:'short', year:'numeric' })}</span>
                  <span class="latest-tipo">{pinned2.data.tipo}</span>
                </div>
                <span class="latest-title">{pinned2.data.title}</span>
              </a>
            )}
            {latest && (
              <a class="latest-post" href={`/blog/${latest.id}/`}>
                <div class="latest-meta">
                  <span class="live-dot" aria-hidden="true"></span>
                  <span>{latest.data.fecha.toLocaleDateString('es-CL', { day:'numeric', month:'short', year:'numeric' })}</span>
                  <span class="latest-tipo">{latest.data.tipo}</span>
                </div>
                <span class="latest-title">{latest.data.title}</span>
              </a>
            )}
          </div>
        </div>
        <div class="col-group anim d5">
          <div class="eyebrow">música</div>
          <div class="stack">
            <a class="link" href="https://munra.bandcamp.com" target="_blank" rel="noopener"><span class="g" aria-hidden="true">bandcamp</span>bandcamp<span class="arrow">↗</span></a>
            <a class="latest-post" href="https://munra.bandcamp.com" target="_blank" rel="noopener" style="margin-top:.5em;">
              <span class="latest-meta">
                <span class="live-dot" aria-hidden="true"></span>
                <span class="latest-tipo">latest</span>
              </span>
              <span class="latest-title">Primeros samples a mano de un 808</span>
            </a>
          </div>
        </div>
        <div class="col-group anim d5">
          <div class="eyebrow">contacto</div>
          <div class="stack">
            <span class="artifact-desc">Escríbeme acá:</span>
            <form class="contact-form" action="https://formspree.io/f/xdarggap" method="POST">
              <input class="contact-input" type="email" name="email" placeholder="tu email" required />
              <textarea class="contact-input" name="message" placeholder="tu mensaje acá" rows="3" required></textarea>
              <button class="contact-btn" type="submit">enviar →</button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="foot anim d5">
    <span class="foot-name">un lab de rafa sacaan</span>
    <span style="display:flex;align-items:center;gap:.6em;">
      © 2026. All rights reserved.
      <a href="https://www.linkedin.com/in/rafaelsacaanamunategui/" target="_blank" rel="noopener" style="display:flex;align-items:center;opacity:.6;transition:opacity .2s ease;" aria-label="LinkedIn">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
    </span>
  </footer>

  <script is:inline>
    // dot canvas
    (function(){
      const canvas = document.getElementById('dot-canvas');
      const ctx = canvas.getContext('2d');
      const SPACING = 28;
      const RADIUS = 0.8;
      const AMPLITUDE = 10;
      const SPEED = 0.012;

      function resize(){
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
      }
      resize();
      window.addEventListener('resize', resize);

      let t = 0;
      function draw(){
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.fillStyle = 'rgba(14,14,12,0.1)';
        const cols = Math.ceil(canvas.width / SPACING) + 2;
        const rows = Math.ceil(canvas.height / SPACING) + 2;
        for(let r = 0; r < rows; r++){
          for(let c = 0; c < cols; c++){
            const bx = c * SPACING;
            const by = r * SPACING;
            const phase = (c * 0.7 + r * 0.5);
            const dx = Math.sin(t + phase) * AMPLITUDE;
            const dy = Math.cos(t + phase * 0.8) * AMPLITUDE;
            ctx.beginPath();
            ctx.arc(bx + dx, by + dy, RADIUS, 0, Math.PI * 2);
            ctx.fill();
          }
        }
        t += SPEED;
        requestAnimationFrame(draw);
      }
      draw();
    })();

    (function(){
      const head = document.querySelector('.head');
      if(!head || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      // el respiro del wordmark es 100% CSS (breathe-a / breathe-b); ya no hay glitch por JS

      // typewriter secuencial: (def.) → (lab.) → (cred.)
      function typeInto(textEl, cursorEl, text, onDone){
        if(!textEl || !cursorEl){ if(onDone) onDone(); return; }
        cursorEl.classList.add('typing');
        let i = 0;
        const iv = setInterval(() => {
          textEl.textContent = text.slice(0, ++i);
          if(i >= text.length){
            clearInterval(iv);
            cursorEl.classList.remove('typing');
            cursorEl.classList.add('done');
            if(onDone) setTimeout(onDone, 250);
          }
        }, 32);
      }

      const defPlain = 'Cuando algo se hace o es cierto independiente de los obstáculos o de lo que piensen los demás.';
      const labPlain = 'Construimos artefactos digitales para personas normales que quieren sacar afuera las ideas que llevan dentro.';
      const credPlain = 'Menos ruido, menos relato, más outcome.';

      const entranceEnd = 400 + 900;
      setTimeout(() => {
        typeInto(document.querySelector('.def-text'), document.querySelector('.def-cursor'), defPlain, () => {
          typeInto(document.querySelector('.lab-text'), document.querySelector('.lab-cursor'), labPlain, () => {
            typeInto(document.querySelector('.cred-text'), document.querySelector('.cred-cursor'), credPlain, () => {
              const credText = document.querySelector('.cred-text');
              if(credText) credText.innerHTML = credPlain.replace('outcome', '<em class="lab-em">outcome</em>');
            });
          });
        });
      }, entranceEnd);
    })();
  </script>
</Base>
